{
  "name": "bolt-store",
  "version": "1.0.0",
  "description": "Loja virtual Bolt feita com HTML, CSS, JavaScript puro e JSON Server.",
  "scripts": {
    "dev": "concurrently \"npm run api\" \"npm run site\"",
